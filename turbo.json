{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  // Turbo runs tasks in strict env mode: anything not declared here is hidden from the task.
  "globalPassThroughEnv": ["NODE_OPTIONS"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "cache": false,
      // CI supplies these from the job env; locally each app reads its own .env.
      "passThroughEnv": [
        "DATABASE_URL",
        "REDIS_URL",
        "WEB_ORIGIN",
        "BETTER_AUTH_URL",
        "BETTER_AUTH_SECRET"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
