API_PORT=4000
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgres://yapper:yapper@localhost:5432/yapper
REDIS_URL=redis://localhost:6379

# Better Auth (slice 02). Public base URL of this api; must match the OAuth callback host.
BETTER_AUTH_URL=http://localhost:4000
# Generate a strong secret, e.g. `openssl rand -base64 32`. Keep it out of git.
BETTER_AUTH_SECRET=

# Google OAuth — callback: http://localhost:4000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth — callback: http://localhost:4000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
