{
  "name": "@yapper/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "test": "bun test --timeout 30000",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@yapper/auth": "workspace:*",
    "@yapper/db": "workspace:*",
    "@yapper/permissions": "workspace:*",
    "@yapper/schemas": "workspace:*",
    "better-auth": "^1.3.4",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.44.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/supertest": "^6.0.2",
    "@yapper/typescript-config": "workspace:*",
    "supertest": "^7.0.0",
    "typescript": "5.9.2"
  }
}
