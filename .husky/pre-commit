# Lint, format, and organize imports across the whole repo with Biome.
# `--write` applies all safe fixes in place; the command still exits non-zero
# (aborting the commit) if any unfixable lint error remains.
bunx biome check --write .

# Re-stage the files Biome just fixed so the formatted result is part of the commit.
# `-u` only touches already-tracked files (won't add new untracked ones).
git add -u
