# Shared dev defaults. Copy to .env and adjust as needed.
# Postgres — remote (Neon); grab the connection string from the project dashboard.
DATABASE_URL=postgres://user:password@host.neon.tech/yapper?sslmode=require
# Redis — remote (Upstash); use the rediss:// URL from the database page.
REDIS_URL=rediss://default:password@host.upstash.io:6379
# Dev ports
WEB_PORT=3000
API_PORT=4000
SOCKET_PORT=1234
# CORS / cross-service origins
WEB_ORIGIN=http://localhost:3000
